{
  "version": 2,
  "name": "portofolio-web",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/sitemap.txt",
      "destination": "/sitemap.txt"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.json"
    },
    {
      "source": "/google6116e4c18620528a.html",
      "destination": "/google6116e4c18620528a.html"
    },
    {
      "source": "/favicon.png",
      "destination": "/favicon.png"
    },
    {
      "source": "/og-image.jpg",
      "destination": "/og-image.jpg"
    },
    {
      "source": "/cv.pdf",
      "destination": "/cv.pdf"
    },
    {
      "source": "/logo-sd.png",
      "destination": "/logo-sd.png"
    },
    {
      "source": "/logo-smk.png",
      "destination": "/logo-smk.png"
    },
    {
      "source": "/logo-smp.png",
      "destination": "/logo-smp.png"
    },
    {
      "source": "/gallery-1.jpg",
      "destination": "/gallery-1.jpg"
    },
    {
      "source": "/gallery-2.jpg",
      "destination": "/gallery-2.jpg"
    },
    {
      "source": "/gallery-3.jpg",
      "destination": "/gallery-3.jpg"
    },
    {
      "source": "/gallery-4.jpg",
      "destination": "/gallery-4.jpg"
    },
    {
      "source": "/gallery-5.jpg",
      "destination": "/gallery-5.jpg"
    },
    {
      "source": "/gallery-6.jpg",
      "destination": "/gallery-6.jpg"
    },
    {
      "source": "/gallery-7.jpg",
      "destination": "/gallery-7.jpg"
    },
    {
      "source": "/gallery-8.jpg",
      "destination": "/gallery-8.jpg"
    },
    {
      "source": "/proyek-1.jpg",
      "destination": "/proyek-1.jpg"
    },
    {
      "source": "/proyek-2.jpg",
      "destination": "/proyek-2.jpg"
    },
    {
      "source": "/proyek-3.jpg",
      "destination": "/proyek-3.jpg"
    },
    {
      "source": "/proyek-4.jpg",
      "destination": "/proyek-4.jpg"
    },
    {
      "source": "/pkl-1.jpg",
      "destination": "/pkl-1.jpg"
    },
    {
      "source": "/pkl-2.jpg",
      "destination": "/pkl-2.jpg"
    },
    {
      "source": "/pkl-3.jpg",
      "destination": "/pkl-3.jpg"
    },
    {
      "source": "/sertifikat-1.jpg",
      "destination": "/sertifikat-1.jpg"
    },
    {
      "source": "/sertifikat-2.jpg",
      "destination": "/sertifikat-2.jpg"
    },
    {
      "source": "/sertifikat-3.jpg",
      "destination": "/sertifikat-3.jpg"
    },
    {
      "source": "/sertifikat-4.jpg",
      "destination": "/sertifikat-4.jpg"
    },
    {
      "source": "/sertifikat-5.jpg",
      "destination": "/sertifikat-5.jpg"
    },
    {
      "source": "/sertifikat-6.jpg",
      "destination": "/sertifikat-6.jpg"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*).pdf",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/pdf"
        }
      ]
    },
    {
      "source": "/(.*).jpg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
    }
